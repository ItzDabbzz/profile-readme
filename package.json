{
    "name": "profile-readme",
    "version": "0.2.1",
    "description": "Collection of widgets for your profile README",
    "main": "lib/index.js",
    "repository": "https://github.com/ItzDabbzz/profile-readme.git",
    "author": "Filippo R. (Qu4k)",
    "maintainers": ["ItzDabbzz"],
    "license": "MIT",
    "private": true,
    "husky": {
        "hooks": {
            "pre-commit": "bun export"
        }
    },
    "scripts": {
        "build": "tsup",
        "check": "biome check",
        "check:fix": "biome check --fix",
        "test": "jest",
        "export": "bun check:fix && bun run build && git add dist/index.js"
    },
    "dependencies": {
        "@actions/core": "^3.0.0",
        "@actions/github": "^9.0.0",
        "moment": "^2.30.1",
        "moment-timezone": "^0.6.1",
        "rss-parser": "^3.13.0"
    },
    "devDependencies": {
        "@types/bun": "^1.3.11",
        "@types/node": "^25.5.0",
        "husky": "^9.1.7",
        "prettier": "^3.8.1",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    },
    "trustedDependencies": ["esbuild", "husky"]
}
